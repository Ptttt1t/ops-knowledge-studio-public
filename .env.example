# DeepSeek 官方 OpenAI 兼容接口。复制为 .env 后填写 API Key。
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# enabled / disabled / 留空使用供应商默认值。知识抽取会固定使用 disabled 以保证 JSON 稳定。
DEEPSEEK_THINKING=disabled
DEEPSEEK_TIMEOUT_SECONDS=120
DEEPSEEK_MAX_RETRIES=2
DEEPSEEK_RETRY_INITIAL_SECONDS=0.5
DEEPSEEK_RETRY_MAX_SECONDS=4
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.1

# 本地知识平台
KNOWLEDGE_DB_PATH=data/knowledge.db
KNOWLEDGE_SOURCE_DIR=knowledge_sources
KNOWLEDGE_CHUNK_SIZE=6000
KNOWLEDGE_CHUNK_OVERLAP=500
KNOWLEDGE_TOP_K=6
# 低于任一门槛的候选不会进入可信回答；无强相关知识时直接拒答。
KNOWLEDGE_MIN_SCORE=10
KNOWLEDGE_MIN_COVERAGE=0.15
AGENT_MAX_STEPS=4
# Harness Runtime：任务状态、检查点和事件存放在独立 SQLite；默认两个后台 Worker。
HARNESS_RUNTIME_DB_PATH=data/runtime.db
HARNESS_WORKERS=2
HARNESS_MAX_QUEUED_RUNS=100
HARNESS_SYNC_WAIT_SECONDS=900
PLATFORM_HOST=127.0.0.1
PLATFORM_PORT=8765
